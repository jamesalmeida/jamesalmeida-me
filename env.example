# Environment Variables for Arkham Ventures
# Copy this file to .env.local and fill in your actual values

# Contact Form Email Configuration
# Replace with your email service API key (e.g., Resend, SendGrid, etc.)
# RESEND_API_KEY=your_resend_api_key_here

# Contact email address where form submissions should be sent
CONTACT_EMAIL=info@arkham.ventures

# Optional: Database connection string for storing form submissions
# DATABASE_URL=your_database_connection_string

# Optional: Vercel KV for storing form submissions
# KV_URL=your_vercel_kv_url
# KV_REST_API_URL=your_vercel_kv_rest_api_url
# KV_REST_API_TOKEN=your_vercel_kv_rest_api_token

# Google Site Verification (for Google Search Console)
GOOGLE_SITE_VERIFICATION=your_google_site_verification_code

# Optional: Analytics (Google Analytics, etc.)
# GA_TRACKING_ID=your_google_analytics_tracking_id
